# =============================================
# .gitignore for Core Java Project
# =============================================

# -----------------------------------------------
# Compiled Java class files
# -----------------------------------------------
*.class
*.jar
*.war
*.ear

# -----------------------------------------------
# Build output folders (IntelliJ generates these)
# -----------------------------------------------
out/
build/
target/

# -----------------------------------------------
# IntelliJ IDEA IDE files
# -----------------------------------------------
.idea/
*.iml
*.iws
*.ipr

# -----------------------------------------------
# VS Code settings
# -----------------------------------------------
.vscode/

# -----------------------------------------------
# Eclipse IDE files (just in case)
# -----------------------------------------------
.classpath
.project
.settings/

# -----------------------------------------------
# Mac system files
# -----------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------
# Windows system files
# -----------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------
# Log files
# -----------------------------------------------
*.log

# -----------------------------------------------
# Package files
# -----------------------------------------------
*.zip
*.tar.gz
*.rar